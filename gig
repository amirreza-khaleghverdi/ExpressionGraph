division with shift left
ORG 100
        LDA DVSR    ; Divisor
        STA D       ; Store divisor
        LDA DVDND   ; Dividend
        STA REM     ; Remainder starts as dividend
        CLA
        STA QUO     ; Quotient starts at 0
        
        LDA CTR
        STA COUNT   ; Initialize counter

LOOP,   CLE
        LDA QUO     ; Shift quotient left
        CIL
        STA QUO
        
        LDA REM     ; Shift remainder left  
        CIL
        STA REM
        
        ; Try subtracting divisor from remainder
        LDA REM
        SUB D
        SNA         ; Skip if result negative
        BUN SUBTRACT ; Can subtract
        
        ; Cannot subtract - restore and continue
        BUN NEXT

SUBTRACT, STA REM   ; Store new remainder
          LDA QUO   ; Set quotient LSB to 1
          IAC       ; Increment (set LSB=1)
          STA QUO

NEXT,   ISZ COUNT
        BUN LOOP
        HLT

CTR,    DEC -8      ; 8 iterations
DVDND,  DEC 165     ; Dividend
DVSR,   DEC 15      ; Divisor
QUO,    DEC 0       ; Quotient
REM,    DEC 0       ; Remainder  
D,      DEC 0       ; Divisor copy
COUNT,  DEC 0       ; Counter
END